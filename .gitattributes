# Normalize line endings: LF in the repo, auto on checkout.
* text=auto

# Source files always LF (keeps Linux CI + rustfmt consistent).
*.rs   text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.json text eol=lf
Makefile text eol=lf

# Binary
*.wasm binary
*.png  binary
*.pdf  binary
